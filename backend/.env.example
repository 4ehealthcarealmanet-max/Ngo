DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=your-domain.com

# CORS / CSRF (comma-separated)
CORS_ALLOW_ALL_ORIGINS=0
# CORS_ALLOWED_ORIGINS=https://your-frontend.com
# CSRF_TRUSTED_ORIGINS=https://your-frontend.com

# Database (preferred: full URL via dj-database-url)
# NOTE: if your password contains special chars like '@', URL-encode them (%40).
DATABASE_URL=postgresql://postgres:change-me@db.example.supabase.co:5432/postgres
DJANGO_DB_SSL_REQUIRE=1
DJANGO_DB_CONN_MAX_AGE=600
# Temporary export/migration helper (forces local SQLite regardless of DATABASE_URL)
DJANGO_USE_SQLITE=0

# Optional (fallback) split-credentials config; if not set, SQLite is used
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=ngo
# DJANGO_DB_USER=postgres
# DJANGO_DB_PASSWORD=postgres
# DJANGO_DB_HOST=127.0.0.1
# DJANGO_DB_PORT=5432
